# =============================================================================
# VibeCheck Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# LLM Provider Selection
# -----------------------------------------------------------------------------
# Options: ollama | openrouter
LLM_PROVIDER=ollama

# -----------------------------------------------------------------------------
# Neo4j Aura (Graph Database - Free Tier)
# -----------------------------------------------------------------------------
# Get these from your Neo4j Aura dashboard: https://console.neo4j.io/
# Connection string format: neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-neo4j-password

# -----------------------------------------------------------------------------
# Qdrant Cloud (Vector Database - Free Tier)
# -----------------------------------------------------------------------------
# Get these from your Qdrant Cloud dashboard: https://cloud.qdrant.io/
QDRANT_URL=https://your-instance.us-east4-0.gcp.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# -----------------------------------------------------------------------------
# Upstash Redis (Message Queue / Cache - Free Tier)
# -----------------------------------------------------------------------------
# Get these from your Upstash Redis dashboard: https://console.upstash.com/
# URL format: rediss://default:your-password@your-endpoint.upstash.io:6379
REDIS_URL=rediss://default:your-password@your-endpoint.upstash.io:6379

# -----------------------------------------------------------------------------
# Supabase (Relational Database - Free Tier)
# -----------------------------------------------------------------------------
# Get these from your Supabase dashboard: https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key

# -----------------------------------------------------------------------------
# Ollama (Local LLM via Cloudflare Tunnel)
# -----------------------------------------------------------------------------
# For local development with Cloudflare Tunnel exposing Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Cloudflare Access (Security for Ollama Tunnel)
# -----------------------------------------------------------------------------
# Create a Cloudflare Access application at: https://one.dash.cloudflare.com/
# Required if exposing Ollama via Cloudflare Tunnel
CF_ACCESS_CLIENT_ID=your-cloudflare-access-client-id
CF_ACCESS_CLIENT_SECRET=your-cloudflare-access-client-secret

# -----------------------------------------------------------------------------
# OpenRouter (Cloud LLM - Pay Per Token)
# -----------------------------------------------------------------------------
# Get API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=arcee-ai/trinity-large-preview:free
OPENROUTER_FALLBACK_MODEL=z-ai/glm-4.5-air:free

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_VERSION=v0
ALLOWED_ORIGINS=*

# -----------------------------------------------------------------------------
# Worker Configuration
# -----------------------------------------------------------------------------
MAX_CONCURRENT_SCANS=3
SCAN_TIMEOUT_MS=300000
REPO_CLONE_DIR=/tmp/vibecheck/repos
MAX_REPO_SIZE_MB=500
