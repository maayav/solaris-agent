# Application
NODE_ENV=development
LOG_LEVEL=info

# ===========================================
# FALKORDB (Graph Memory) - RAILWAY (PRODUCTION)
# ===========================================
# FalkorDB on Railway - Primary for production
# Get these values from your Railway project dashboard
FALKORDB_HOST=your-falkordb-host.railway.app
FALKORDB_PORT=6379
FALKORDB_USERNAME=falkordb
FALKORDB_PASSWORD=your-railway-falkordb-password
FALKORDB_DATABASE=0

# ===========================================
# SUPABASE (Persistent Storage)
# ===========================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# SQLITE (Event Bus - LOCAL)
# ===========================================
# SQLite file created automatically at ./solaris-events.db
# SQLITE_EVENTS_PATH=./solaris-events.db

# ===========================================
# OLLAMA (Local LLM) - TIER 1 & 2 AGENTS (Unlimited, RTX 4080)
# ===========================================
# Ollama models: phi-3-mini-128k-instruct-q4_K_M, llama3-groq-tool-use:8b-q4_K_M, qwen2.5-coder:7b-q4_K_M
# Download with: ollama pull <model-name>
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_ENABLED=true

# Per-agent model overrides (optional - defaults below)
# TIER 1 (Nano - 2GB each)
# VERIFIER_MODEL=phi-3-mini-128k-instruct-q4_K_M
# VERIFIER_MODEL_FALLBACK=meta-llama/llama-3.1-8b-instruct
# CRITIC_MODEL=phi-3-mini-128k-instruct-q4_K_M
# CRITIC_MODEL_FALLBACK=meta-llama/llama-3.1-8b-instruct

# TIER 2 (Mid - 4-5GB each)
# GAMMA_MODEL=llama3-groq-tool-use:8b-q4_K_M
# GAMMA_MODEL_FALLBACK=gpt-oss-120b
# ALPHA_MODEL=qwen2.5-coder:7b-q4_K_M
# ALPHA_MODEL_FALLBACK=meta-llama/llama-3.1-8b-instruct
# MCP_MODEL=llama3-groq-tool-use:8b-q4_K_M
# MCP_MODEL_FALLBACK=gpt-oss-120b
# SPECIALIST_MODEL=llama3-groq-tool-use:8b-q4_K_M
# SPECIALIST_MODEL_FALLBACK=gpt-oss-120b
# POST_MODEL=qwen2.5-coder:7b-q4_K_M
# POST_MODEL_FALLBACK=gpt-oss-120b

# ===========================================
# CEREBRAS - SWARM BACKBONE (14,400 RPD + 1M tokens/day FREE!)
# ===========================================
# Get from https://cloud.cerebras.ai/
# Models: gpt-oss-120b (best quality), llama-3.1-8b
CEREBRAS_API_KEY=

# ===========================================
# GROQ - TIER 3 REASONING (1K-14,400 RPD free)
# ===========================================
# Get from https://console.groq.com/
# Models: moonshotai/kimi-k2-instruct (best reasoning), llama-3.1-8b (14,400 RPD), llama-3.3-70b (1K RPD)
GROQ_API_KEY=

# ===========================================
# GOOGLE AI STUDIO - TIER 4 FALLBACK (14,400 RPD!)
# ===========================================
# Get from https://aistudio.google.com/app/apikey
# Models: google/gemma-3-27b-it (14,400 RPD, 30 RPM)
GOOGLE_API_KEY=

# ===========================================
# OPENROUTER - LAST RESORT ONLY (50 RPD free!)
# ===========================================
# Get from https://openrouter.ai/keys
# WARNING: Only 50 RPD free - use only with $10 topup
# Models: gpt-oss-120b:free, gemma-3-27b:free
OPENROUTER_API_KEY=

# ===========================================
# ANTHROPIC - FALLBACK ONLY
# ===========================================
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ===========================================
# MINIMAX - TIER 5 (50 RPD free!)
# ===========================================
# Get from https://platform.minimaxi.com/
MINIMAX_API_KEY=
# Models: Check your dashboard for available models
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# Per-agent model overrides for cloud (optional)
# TIER 3 (Reasoning - Groq)
# COMMANDER_MODEL=moonshotai/kimi-k2-instruct
# COMMANDER_MODEL_FALLBACK=meta-llama/llama-3.3-70b-instruct
# TIER 4 (Planning - Cerebras primary, Google fallback)
# PLANNER_MODEL=gpt-oss-120b
# PLANNER_MODEL_FALLBACK=google/gemma-3-27b-it
# CHAIN_MODEL=gpt-oss-120b
# CHAIN_MODEL_FALLBACK=qwen/qwen3-32b
# OSINT_MODEL=meta-llama/llama-3.1-8b-instruct
# OSINT_MODEL_FALLBACK=google/gemma-3-27b-it
# TIER 5 (Output - Cerebras)
# REPORT_MODEL=gpt-oss-120b
# REPORT_MODEL_FALLBACK=openai/gpt-oss-120b:free

# ===========================================
# OSINT AGENT APIs
# ===========================================
# Tavily (best for AI agents) - https://app.tavily.com
# Free tier: 1,000 searches/month
TAVILY_API_KEY=

# NVD API v2 (CVE/CVSS data) - https://nvd.nist.gov/developers/request-an-api-key
# Free tier: 50 requests/30 seconds with API key
NVD_API_KEY=

# ===========================================
# AGENT CONFIGURATION
# ===========================================
# Set at runtime by PM2
# AGENT_ROLE=commander
# AGENT_INSTANCE_ID=commander-1

# ===========================================
# SECURITY
# ===========================================
AUTHORIZATION_HMAC_SECRET=change-this-secret-in-production
CREDENTIAL_VAULT_KEY=your-fernet-key-here
