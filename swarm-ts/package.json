    "@supabase/supabase-js": "^2.39.0",
    "zod": "^3.22.0",
    "ai": "^3.0.0",
    "ws": "^8.16.0",
    "dotenv": "^16.4.0",
    "yaml": "^2.3.0",
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "bun-types": "^1.0.0",
    "typescript": "^5.3.0",
    "@types/ws": "^8.5.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "vitest": "^1.2.0"
