{
  "name": "swarm",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/api/index.ts",
    "build": "bun build src/api/index.ts --outdir dist --target bun",
    "start": "bun run src/api/index.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
