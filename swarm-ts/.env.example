# Application
NODE_ENV=development
LOG_LEVEL=info

# ===========================================
# FALKORDB (Graph Memory) - RAILWAY (PRODUCTION)
# ===========================================
# FalkorDB on Railway - Primary for production
# Get these values from your Railway project dashboard
FALKORDB_HOST=your-falkordb-host.railway.app
FALKORDB_PORT=6379
FALKORDB_USERNAME=falkordb
FALKORDB_PASSWORD=your-railway-falkordb-password
FALKORDB_DATABASE=0

# LOCAL DEVELOPMENT (Alternative to Railway)
# Uncomment below and comment out Railway settings above
# Only use when running FalkorDB locally via docker-compose
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6379
# FALKORDB_USERNAME=falkordb
# FALKORDB_PASSWORD=falkordb_dev_password

# ===========================================
# QDRANT (Vector Store)
# ===========================================
QDRANT_URL=https://xxx.us-east-1-0.qdrant.cloud
QDRANT_API_KEY=your-api-key

# ===========================================
# SUPABASE (Persistent Storage)
# ===========================================
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJxxx
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# SQLITE (Event Bus - LOCAL)
# ===========================================
# SQLite file created automatically at ./solaris-events.db
# SQLITE_EVENTS_PATH=./solaris-events.db

# ===========================================
# OLLAMA (Local LLM)
# ===========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_ENABLED=false

# ===========================================
# AGENT CONFIGURATION
# ===========================================
# Set at runtime by PM2
# AGENT_ROLE=commander
# AGENT_INSTANCE_ID=commander-1

# ===========================================
# SECURITY
# ===========================================
AUTHORIZATION_HMAC_SECRET=change-this-secret-in-production
CREDENTIAL_VAULT_KEY=your-fernet-key-here
