SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5lc2phb2RycmtlZnBtcWRxdGd2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzExMTg0MjcsImV4cCI6MjA4NjY5NDQyN30.zbEAwOcZ7Tn-LVfGC8KdQeh3D3xEyzghZ-Mfg0VgnfE

# -------------------------------------------
# OpenRouter Configuration (Free Tier)
# -------------------------------------------
# Get your API key from: https://openrouter.ai/keys
# Used for cloud LLM fallback (Gemini 2.0 Flash, Llama 3.3 70B)
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenRouter models for verification (can be customized)
OPENROUTER_PRIMARY_MODEL=qwen/qwen3-235b-a22b:free
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-r1-0528:free

# HTTP Referer header for OpenRouter API (identifies your app)
OPENROUTER_HTTP_REFERER=https://vibecheck.local

# -------------------------------------------
# Local Services (Docker)
# -------------------------------------------
# These are the default ports from docker-compose.yml

# FalkorDB - Graph Database (Redis-compatible)
FALKORDB_URL=redis://localhost:6379

# Qdrant - Vector Database
QDRANT_URL=http://localhost:6333

# Redis - Message Bus (Note: port 6380 to avoid FalkorDB conflict)
REDIS_URL=redis://localhost:6380

# -------------------------------------------
# Ollama Configuration (Local LLM)
# -------------------------------------------
# Ollama should be running on the host machine
# Install: curl -fsSL https://ollama.com/install.sh | sh
# Pull models: 
#   ollama pull qwen2.5-coder:7b-instruct
#   ollama pull nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434

# Model names (defaults)
OLLAMA_CODER_MODEL=qwen2.5-coder:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

# -------------------------------------------
# Application Settings
# -------------------------------------------
# Environment: development | production
ENVIRONMENT=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# API server port
API_PORT=8000

# -------------------------------------------
# Scan Settings
# -------------------------------------------
# Maximum concurrent scans
MAX_CONCURRENT_SCANS=3

# Clone directory for repositories
REPO_CLONE_DIR=/tmp/vibecheck/repos

# Maximum repository size (MB)
MAX_REPO_SIZE_MB=500

# Semgrep binary path (isolated venv to avoid dependency conflicts)
# Create isolated venv: python -m venv .semgrep-venv
# Install semgrep: .semgrep-venv/Scripts/pip install semgrep (Windows)
#                 .semgrep-venv/bin/pip install semgrep (Linux/Mac)
# SEMGREP_BIN=/path/to/solaris-agent/.semgrep-venv/Scripts/semgrep.exe
