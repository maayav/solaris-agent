# Red Team Configuration - Shared with Blue Team (vibecheck)
# All services are already running via vibecheck's docker-compose

# ============================================
# Docker Compose Ports (customize if ports are already in use)
# ============================================
JUICE_SHOP_PORT=8080
REDIS_PORT=6381

# ============================================
# Redis (Message Bus) - SHARED
# Blue Team Redis runs on port 6380
# Both teams use same Redis but different streams
# ============================================
REDIS_URL=redis://localhost:6380

# ============================================
# Ollama (Local LLMs) - SEPARATE
# You need to install Ollama separately
# ============================================
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# OpenRouter (Cloud LLMs - Optional)
# ============================================
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Target Application - SHARED
# Blue Team Juice Shop runs on port 8080
# ============================================
JUICE_SHOP_URL=http://localhost:8080

# ============================================
# Blue Team API - For auto-triggering scans
# Red Team can trigger Blue Team scans if no findings exist
# ============================================
BLUE_TEAM_API_URL=http://localhost:8000

# ============================================
# Model Selection (OpenRouter primary, Ollama fallback)
# ============================================
# Models with "/" use OpenRouter API first, fallback to Ollama
# Models without "/" go directly to Ollama (offline mode)

# OpenRouter models (RECOMMENDED - better quality)
COMMANDER_MODEL=arcee-ai/trinity-large-preview:free
RECON_MODEL=stepfun/step-3.5-flash:free
EXPLOIT_MODEL=upstage/solar-pro-3:free
CRITIC_MODEL=arcee-ai/trinity-large-preview:free

# Fallback to Ollama if OpenRouter fails
COMMANDER_MODEL_FALLBACK=llama3:latest
RECON_MODEL_FALLBACK=qwen2.5-coder:7b-instruct
EXPLOIT_MODEL_FALLBACK=qwen2.5-coder:7b-instruct
CRITIC_MODEL_FALLBACK=llama3:latest

# Ollama-only mode (for offline use)
# COMMANDER_MODEL=qwen2.5-coder:7b-instruct
# RECON_MODEL=qwen2.5-coder:7b-instruct
# EXPLOIT_MODEL=qwen2.5-coder:7b-instruct
# CRITIC_MODEL=qwen2.5-coder:7b-instruct

# ============================================
# Blue Team Integration (Optional)
# These connect to Blue Team for intel
# ============================================
QDRANT_URL=http://localhost:6333
FALKORDB_URL=redis://localhost:6379

# ============================================
# HITL & Safety
# ============================================
HITL_TIMEOUT_SECONDS=120
MAX_REFLECTION_ITERATIONS=3
